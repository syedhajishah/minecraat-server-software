{
    "name": "minecraft-server-panel",
    "version": "0.1.0",
    "description": "Local web control panel for a Purpur/Paper Minecraft server.",
    "main": "server.js",
    "scripts": {
        "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
        "build": "tsc",
        "start": "node dist/index.js",
        "lint": "eslint . --ext .ts,.js",
        "format": "prettier --write .",
        "hash-password": "node -e \"const bcrypt = require('bcrypt'); const password = process.argv[2] || 'admin123'; bcrypt.hash(password, 10).then(hash => console.log('Password hash:', hash)).catch(console.error);\"",
        "pm2:start": "pm2 start ecosystem.config.js",
        "pm2:stop": "pm2 stop ecosystem.config.js"
    },
    "dependencies": {
        "adm-zip": "^0.5.10",
        "archiver": "^6.0.1",
        "bcrypt": "^5.1.1",
        "compression": "^1.7.4",
        "cookie-parser": "^1.4.7",
        "csurf": "^1.11.0",
        "dotenv": "^16.3.1",
        "express": "^4.18.4",
        "express-rate-limit": "^7.1.5",
        "express-session": "^1.17.4",
        "helmet": "^7.1.0",
        "http-errors": "^2.0.0",
        "jsonwebtoken": "^9.0.2",
        "multer": "^1.4.5-lts.1",
        "pg": "^8.11.2",
        "connect-pg-simple": "^8.0.0",
        "prisma": "^5.15.0",
        "socket.io": "^4.7.2",
        "winston": "^3.11.0",
        "@prisma/client": "^5.15.0"
    },
    "devDependencies": {
        "@types/adm-zip": "^0.5.15",
        "@types/bcrypt": "^5.0.3",
        "@types/cookie-parser": "^1.4.3",
        "@types/csurf": "^1.11.3",
        "@types/express": "^4.17.19",
        "@types/express-session": "^1.17.6",
        "@types/jsonwebtoken": "^9.0.2",
        "@types/multer": "^1.4.7",
        "@types/node": "^20.14.0",
        "@types/connect-pg-simple": "^7.0.0",
        "@types/socket.io": "^4.6.4",
        "@typescript-eslint/eslint-plugin": "^7.49.0",
        "@typescript-eslint/parser": "^7.49.0",
        "eslint": "^8.57.0",
        "eslint-config-prettier": "^9.0.0",
        "eslint-plugin-import": "^2.29.5",
        "eslint-plugin-node": "^11.1.0",
        "eslint-plugin-promise": "^6.1.1",
        "pm2": "^5.3.0",
        "prettier": "^3.0.0",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.6.0"
    }
}